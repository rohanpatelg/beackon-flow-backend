# Server Configuration
PORT=8080
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database Configuration (Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Configuration (for backward compatibility)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# LLM Provider Selection
# Controls which provider handles chat completions. Embeddings always use OpenAI.
# Values: openai (default) | claude
LLM_PROVIDER=openai

# OpenAI — required for embeddings regardless of LLM_PROVIDER;
# required for chat when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional chat model override (OpenAI only)
# OPEN_AI_MODEL=gpt-5-2025-08-07

# Anthropic — required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Cognitive memory configuration
COGNITION_TOP_K=4

# Inspiration Feature Configuration
INSPIRATION_MIN_POSTS=5
INSPIRATION_SUGGESTION_COUNT=5
